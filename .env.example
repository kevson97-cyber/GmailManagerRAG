# ─────────────────────────────────────────────────────────────────────────────
# GmailManagerRAG — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (local AI — free, no API key needed) ───────────────────────────────
# Make sure Ollama is installed and running: https://ollama.com
# Then pull the model once:  ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── How many emails to fetch per sync ────────────────────────────────────────
MAX_EMAILS_PER_SYNC=500

# ── ngrok auth token (only needed for run_mobile.bat) ────────────────────────
# Free account at https://ngrok.com — token at https://dashboard.ngrok.com/authtokens
# NGROK_AUTHTOKEN=your_token_here
