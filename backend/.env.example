# ─────────────────────────────────────────────────────────────────────────────
# GmailManagerRAG backend — Environment Variables
# Copy this file to .env (in this backend/ directory) and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── API auth ──────────────────────────────────────────────────────────────────
# Required. Every request (except GET /api/health) must send
# "Authorization: Bearer <API_TOKEN>". Generate a random 32-byte token with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API (your local
# frontend dev server, plus your deployed Vercel URL once you have one).
ALLOWED_ORIGINS=http://localhost:3000

# ── Ollama (local AI — free, no API key needed) ───────────────────────────────
# Make sure Ollama is installed and running: https://ollama.com
# Then pull the model once:  ollama pull qwen3:4b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ── How many emails to fetch per sync ────────────────────────────────────────
MAX_EMAILS_PER_SYNC=500
