# Copy to .env.local for local `npm run dev`, or set these as Vercel project
# env vars. Both are only used as fallbacks — the in-app Settings sheet
# (localStorage) always takes priority, so a deployed frontend can be pointed
# at a fresh Cloudflare quick-tunnel URL from any device without a rebuild.
#
# Prefer leaving NEXT_PUBLIC_API_TOKEN unset in a public/Vercel build and
# entering the token per-device in Settings instead — anything prefixed
# NEXT_PUBLIC_ is bundled into the client JS and visible to anyone who loads
# the page.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TOKEN=
